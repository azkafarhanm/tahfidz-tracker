{
  "name": "tahfidzflow-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "npm run db:generate && npm run db:validate && npm run lint && npm run typecheck && npm run test && npm run build",
    "verify:fast": "npm run db:generate && npm run db:validate && npm run lint && npm run typecheck",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed:base": "tsx prisma/seed.ts",
    "db:seed:summative": "tsx prisma/seed-summative.ts",
    "db:seed": "npm run db:seed:base && npm run db:seed:summative",
    "db:reset-uat": "tsx prisma/reset-uat-data.ts",
    "db:cleanup-production": "tsx prisma/cleanup-production.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@fontsource/amiri": "^5.2.8",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.11.0",
    "next": "^15.5.18",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.11.1",
    "next-themes": "^0.4.6",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@swc/helpers": "^0.5.21",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.18",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
