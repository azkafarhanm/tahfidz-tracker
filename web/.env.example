# Local development settings for the Next.js web app.
# Copy this file to .env and fill in real values locally.
# Never commit real secrets.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

AUTH_SECRET="replace-with-a-random-secret"

# Production URL (Required for production, omit for local dev)
# AUTH_URL="https://your-domain.com"

# Upstash Redis (Recommended for rate limiting)
# KV_REST_API_URL="https://xxx.upstash.io"
# KV_REST_API_TOKEN=""

APP_DEFAULT_LOCALE="id"

# Optional
# DATABASE_POOL_MAX=10
# APP_CACHE_DEBUG=true
# APP_MEMORY_CACHE_MAX_ENTRIES=500
