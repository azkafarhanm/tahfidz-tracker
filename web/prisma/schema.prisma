generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-next"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEACHER
}

enum Gender {
  MALE
  FEMALE
}

enum HalaqahLevel {
  LOW
  MEDIUM
  HIGH
}

enum RecordStatus {
  LANCAR
  CUKUP
  PERLU_MUROJAAH
}

enum TargetType {
  HAFALAN
  MUROJAAH
}

enum TargetStatus {
  ACTIVE
  COMPLETED
  MISSED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         UserRole @default(TEACHER)
  locale       String   @default("id")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teacher  Teacher?
  accounts Account[]
  sessions Session[]

  @@index([role])
}

model Teacher {
  id             String   @id @default(cuid())
  userId         String   @unique
  fullName       String
  phoneNumber    String?
  telegramUserId String?  @unique
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes             ClassGroup[]
  students            Student[]
  memorizationRecords MemorizationRecord[]
  revisionRecords     RevisionRecord[]
  targets             Target[]

  @@index([isActive])
}

model AcademicClass {
  id           String   @id @default(cuid())
  grade        Int
  section      String
  name         String
  academicYear String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  students Student[]

  @@unique([name, academicYear])
  @@index([grade])
  @@index([isActive])
}

model ClassGroup {
  id          String       @id @default(cuid())
  teacherId   String
  name        String
  description String?
  level       HalaqahLevel @default(LOW)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  teacher  Teacher   @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  students Student[]

  @@index([teacherId])
  @@index([level])
  @@index([isActive])
}

model Student {
  id              String   @id @default(cuid())
  teacherId       String
  classGroupId    String
  academicClassId String?
  fullName        String
  gender          Gender?
  joinDate        DateTime @default(now())
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teacher             Teacher              @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  classGroup          ClassGroup           @relation(fields: [classGroupId], references: [id], onDelete: Restrict)
  academicClass       AcademicClass?       @relation(fields: [academicClassId], references: [id], onDelete: Restrict)
  memorizationRecords MemorizationRecord[]
  revisionRecords     RevisionRecord[]
  targets             Target[]

  @@index([teacherId])
  @@index([classGroupId])
  @@index([academicClassId])
  @@index([fullName])
  @@index([isActive])
}

model MemorizationRecord {
  id        String       @id @default(cuid())
  studentId String
  teacherId String
  surah     String
  fromAyah  Int
  toAyah    Int
  date      DateTime     @default(now())
  status    RecordStatus @default(CUKUP)
  score     Int?
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([teacherId])
  @@index([date])
  @@index([surah])
}

model RevisionRecord {
  id        String       @id @default(cuid())
  studentId String
  teacherId String
  surah     String
  fromAyah  Int
  toAyah    Int
  date      DateTime     @default(now())
  status    RecordStatus @default(CUKUP)
  score     Int?
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([teacherId])
  @@index([date])
  @@index([surah])
}

model Target {
  id        String       @id @default(cuid())
  studentId String
  teacherId String
  type      TargetType
  surah     String
  fromAyah  Int
  toAyah    Int
  startDate DateTime
  endDate   DateTime
  status    TargetStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([teacherId])
  @@index([status])
  @@index([endDate])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
