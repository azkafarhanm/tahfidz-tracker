generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma-next"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEACHER
}

enum Gender {
  MALE
  FEMALE
}

enum HalaqahLevel {
  LOW
  MEDIUM
  HIGH
}

enum RecordStatus {
  LANCAR
  CUKUP
  PERLU_MUROJAAH
}

enum TargetType {
  HAFALAN
  MUROJAAH
}

enum TargetStatus {
  ACTIVE
  COMPLETED
  MISSED
  CANCELLED
}

enum Semester {
  GANJIL
  GENAP
}

enum AcademicYearStatus {
  ACTIVE
  ARCHIVED
}

enum ProgramType {
  ACADEMIC
  BOARDING
}

enum TasmiGrade {
  MUMTAZ
  JAYYID_JIDDAN
  JAYYID
  MAQBUL
}

enum TasmiStatus {
  LULUS
  MENGULANG
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  email        String   @unique
  passwordHash String?
  role         UserRole @default(TEACHER)
  locale       String   @default("id")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teacher   Teacher?
  accounts  Account[]
  sessions  Session[]
  auditLogs AuditLog[]

  @@index([role])
}

model Teacher {
  id             String   @id @default(cuid())
  userId         String   @unique
  fullName       String
  phoneNumber    String?
  telegramUserId String?  @unique
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  classes             ClassGroup[]
  students            Student[]
  memorizationRecords MemorizationRecord[]
  revisionRecords     RevisionRecord[]
  targets             Target[]
  tasmiRecords        TasmiRecord[]

  @@index([isActive])
}

model AcademicYear {
  id        String             @id @default(cuid())
  year      String             @unique
  startDate DateTime
  endDate   DateTime
  isActive  Boolean            @default(false)
  status    AcademicYearStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([isActive])
  @@index([status])
}

model AcademicClass {
  id           String      @id @default(cuid())
  grade        Int
  section      String
  name         String
  academicYear String
  programType  ProgramType @default(ACADEMIC)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  students Student[]

  @@unique([name, academicYear, programType])
  @@index([grade])
  @@index([isActive])
  @@index([programType])
}

model ClassGroup {
  id           String       @id @default(cuid())
  teacherId    String
  academicYear String
  grade        Int          @default(7)
  name         String
  description  String?
  level        HalaqahLevel @default(LOW)
  programType  ProgramType  @default(ACADEMIC)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  teacher  Teacher   @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  students Student[]

  @@index([teacherId])
  @@index([academicYear])
  @@index([grade])
  @@index([level])
  @@index([isActive])
  @@index([teacherId, isActive, grade, level])
  @@index([programType])
  @@unique([teacherId, academicYear, grade, programType])
}

model Student {
  id              String   @id @default(cuid())
  teacherId       String
  classGroupId    String
  academicClassId String?
  fullName        String
  gender          Gender?
  joinDate        DateTime @default(now())
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teacher             Teacher              @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  classGroup          ClassGroup           @relation(fields: [classGroupId], references: [id], onDelete: Restrict)
  academicClass       AcademicClass?       @relation(fields: [academicClassId], references: [id], onDelete: Restrict)
  memorizationRecords MemorizationRecord[]
  revisionRecords     RevisionRecord[]
  targets             Target[]
  summativeScores     SummativeScore[]
  tasmiRecords        TasmiRecord[]

  @@index([teacherId])
  @@index([classGroupId])
  @@index([academicClassId])
  @@index([fullName])
  @@index([isActive])
  @@index([teacherId, isActive])
  @@index([teacherId, isActive, fullName])
}

model MemorizationRecord {
  id           String       @id @default(cuid())
  studentId    String
  teacherId    String
  surah        String
  fromAyah     Int
  toAyah       Int
  date         DateTime     @default(now())
  status       RecordStatus @default(CUKUP)
  score        Int?
  notes        String?
  academicYear String
  semester     Semester
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([teacherId])
  @@index([date])
  @@index([surah])
  @@index([studentId, date])
  @@index([teacherId, date])
  @@index([teacherId, status])
  @@index([teacherId, studentId, date])
  @@index([studentId, status, date])
  @@index([academicYear])
  @@index([semester])
  @@index([studentId, academicYear, semester])
}

model RevisionRecord {
  id           String       @id @default(cuid())
  studentId    String
  teacherId    String
  surah        String
  fromAyah     Int
  toAyah       Int
  date         DateTime     @default(now())
  status       RecordStatus @default(CUKUP)
  score        Int?
  notes        String?
  academicYear String
  semester     Semester
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([teacherId])
  @@index([date])
  @@index([surah])
  @@index([studentId, date])
  @@index([teacherId, date])
  @@index([teacherId, status])
  @@index([teacherId, studentId, date])
  @@index([studentId, status, date])
  @@index([academicYear])
  @@index([semester])
  @@index([studentId, academicYear, semester])
}

model Target {
  id        String       @id @default(cuid())
  studentId String
  teacherId String
  type      TargetType
  surah     String
  fromAyah  Int
  toAyah    Int
  startDate DateTime
  endDate   DateTime
  status    TargetStatus @default(ACTIVE)
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([teacherId])
  @@index([status])
  @@index([endDate])
  @@index([studentId, status])
  @@index([teacherId, status, endDate])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Surah {
  id         String @id @default(cuid())
  number     Int    @unique
  name       String
  arabicName String
  totalAyahs Int
  juz        Int
  orderIndex Int    @unique

  summativeScores SummativeScore[]
  targetSurahs    TargetSurah[]

  @@index([juz])
  @@index([name])
}

model SummativeScore {
  id           String   @id @default(cuid())
  studentId    String
  surahId      String
  semester     Semester
  academicYear String
  score        Int
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  surah   Surah   @relation(fields: [surahId], references: [id], onDelete: Restrict)

  @@unique([studentId, surahId, semester, academicYear])
  @@index([studentId])
  @@index([surahId])
  @@index([semester])
  @@index([academicYear])
  @@index([studentId, semester, academicYear])
}

model TargetSurah {
  id          String   @id @default(cuid())
  classLevel  Int
  semester    Semester
  surahId     String
  isRequired  Boolean  @default(true)
  academicYear String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  surah Surah @relation(fields: [surahId], references: [id], onDelete: Cascade)

  @@unique([classLevel, semester, surahId, academicYear])
  @@index([classLevel])
  @@index([semester])
  @@index([classLevel, semester, academicYear])
}

model TasmiRecord {
  id           String      @id @default(cuid())
  studentId    String
  teacherId    String
  juz          Int
  grade        TasmiGrade
  status       TasmiStatus
  examinerName String
  date         DateTime    @default(now())
  notes        String?
  academicYear String
  semester     Semester
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Restrict)

  @@index([studentId])
  @@index([teacherId])
  @@index([juz])
  @@index([academicYear])
  @@index([semester])
  @@index([studentId, academicYear, semester])
  @@index([studentId, createdAt])
  @@index([teacherId, academicYear])
  @@index([grade])
  @@index([status])
}

enum AuditAction {
  DELETE_STUDENT
  DELETE_ARCHIVED_STUDENTS
  DELETE_ACADEMIC_YEAR
  CREATE_TASMI
  UPDATE_TASMI
  DELETE_TASMI
}

model AuditLog {
  id             String      @id @default(cuid())
  userId         String?
  action         AuditAction
  academicYearId String?
  academicYear   String?
  targetType     String
  targetId       String?
  targetName     String?
  metadata       Json?
  createdAt      DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([academicYearId])
  @@index([createdAt])
}
