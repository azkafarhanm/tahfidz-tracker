# Tahfidz Tracker environment example
# Copy this file to .env for local Next.js development.
# Never put real secrets in this file.

# Database (Required)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Authentication (Required)
AUTH_SECRET="replace-with-a-random-secret"

# Production URL (Required for production, omit for local dev)
# AUTH_URL="https://your-domain.com"

# Upstash Redis (Recommended for rate limiting)
# KV_REST_API_URL="https://xxx.upstash.io"
# KV_REST_API_TOKEN=""

# App settings
APP_DEFAULT_LOCALE="id"

# Optional
# DATABASE_POOL_MAX=10
# APP_CACHE_DEBUG=true
# APP_MEMORY_CACHE_MAX_ENTRIES=500
