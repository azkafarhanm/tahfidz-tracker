# TahfidzFlow v1.0.0 — Production environment template
# Set these in Vercel > Project > Settings > Environment Variables (Production).
# NEVER commit real values. This file contains placeholders only.
# See docs/DEPLOYMENT.md for the full guide.

# --- Required ---

# Neon PostgreSQL connection string. Must include sslmode=require (or verify-full).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DATABASE?sslmode=require"

# NextAuth JWT signing secret. Generate a fresh one: openssl rand -base64 32
# Do NOT reuse the development secret.
AUTH_SECRET="replace-with-a-freshly-generated-32-byte-base64-secret"

# Exact production URL, no trailing slash. (Do NOT set NEXTAUTH_URL; the app uses AUTH_URL.)
AUTH_URL="https://your-domain.com"

# --- Recommended (rate limiting persistence) ---
# Without these, login rate limiting falls back to per-instance in-memory mode.
KV_REST_API_URL="https://xxxx.upstash.io"
KV_REST_API_TOKEN="replace-with-upstash-rest-token"

# --- Optional ---
# Default locale (id | en | ar). Defaults to id.
APP_DEFAULT_LOCALE="id"

# Max Prisma pool connections. Defaults to 10 (production).
# DATABASE_POOL_MAX=10

# Cache hit/miss logging. Leave unset in production.
# APP_CACHE_DEBUG=true

# Max in-memory cache entries. Defaults to 500.
# APP_MEMORY_CACHE_MAX_ENTRIES=500
