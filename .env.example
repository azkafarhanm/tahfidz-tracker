# Tahfidz Tracker environment example
# Copy this file to .env.local for local Next.js development.
# Never put real secrets in this file.

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Authentication
AUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# App settings
APP_DEFAULT_LOCALE="id"

# Future Telegram integration
TELEGRAM_BOT_TOKEN=""

# Future AI parser integration
GEMINI_API_KEY=""
